	)
	(text "RTC-Clock (rd)\nBIOS settings (EEPROM) (rd/wr)\nConsole (USART0)(INT1) / Debug (USART1)(INT2)\nPS2 Keyboard (USART or GPIO?) (INT5)\nSystem Timer (OS-ticks) (INT0)\nProgrammable Timer(s) (INT3+4)"
		(exclude_from_sim no)
		(at 120.904 184.404 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3729ef1e-0345-4ca8-9c6f-76f571fb686e")
	)
	(text "SYSINT0-2\n7 interrupts"
		(exclude_from_sim no)
		(at 111.76 143.51 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "74c8871f-e0e6-4dc7-a6b1-3a66fba3ed16")
	)
	(text "Realtime Clock (no INT):\n- CMD: RTC-DATE\n	- RD: Year (?)\n	- RD: Month (1-12)\n	- RD: Day (1-31)\n\n- CMD: RTC-TIME (can stop reading at any time)\n	- RD: Hour (0-23)\n	- RD: Minute (0-59)\n	- RD: Second (0-59)\n	- RD: Milli (0-99)\n\nBIOS Settings:\n- CMD: SETTING\n	- WR: [address] (0-255)\n	- RD: value / WR: value (0-255)\n\nConsole:\n- CMD: CONSOLE-n (n:0-1)\n	- WR: value (0-255) - output\n	- (or) RD: value (0-255) - input, response to INT\n- STAT: OutputBufferEmpty, InputBufferFull\n- INT: receive input\n\nKeyboard (INT):\n- CMD: KEYBOARD (key-table values)\n	- RD: LSB\n	- RD: MSB\n- INT: receive input\n\nSystem-Timer:\n- INT every tick (100ms).\n\nProg Timers:\n- CMD: TIMER-n (n:0-?)\n	- WR: interval\n- INT every tick\n"
		(exclude_from_sim no)
		(at 224.028 58.674 0)
		(effects
